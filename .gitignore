# Cache do pytest
**/__pycache__/
.pytest_cache/

# Dados do navegador autenticado. Contém dados sensíveis
.playwright/.auth

# Caminho do feedback dos testes. Todos os testes que falharem terão vídeo e trace neste diretório
test-results/

# Arquivo com as credenciais de autenticação. Credenciais são:
# DOMINIO: a base a ser acessada;
# LOGIN: o nome do usuário;
# SENHA: a senha do usuário.
.env

# Arquivo opcional, sendo uma lista de coisas para implementar
todo.txt